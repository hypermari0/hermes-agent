FROM ghcr.io/astral-sh/uv:0.11.6-python3.13-trixie@sha256:b3c543b6c4f23a5f2df22866bd7857e5d304b67a564f4feab6ac22044dde719b AS uv_source
FROM tianon/gosu:1.19-trixie@sha256:3b176695959c71e123eb390d427efc665eeb561b1540e82679c15e992006b8b9 AS gosu_source
FROM caddy:2.8-alpine AS caddy_source
FROM debian:13.4

ENV PYTHONUNBUFFERED=1
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/hermes/.playwright

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential nodejs npm python3 ripgrep ffmpeg gcc python3-dev libffi-dev procps git openssh-client docker-cli ca-certificates && \
    rm -rf /var/lib/apt/lists/*

RUN useradd -u 10000 -m -d /opt/data hermes

COPY --chmod=0755 --from=gosu_source /gosu /usr/local/bin/
COPY --chmod=0755 --from=uv_source /usr/local/bin/uv /usr/local/bin/uvx /usr/local/bin/
COPY --chmod=0755 --from=caddy_source /usr/bin/caddy /usr/local/bin/caddy

WORKDIR /opt/hermes

# --- npm: top-level deps (root + Playwright host) -----------------------------
# Split so an unrelated change (web deps, source code) does NOT re-trigger the
# 5-minute Playwright chromium download. Only re-runs when the root
# package-lock.json changes.
COPY package.json package-lock.json ./
RUN npm install --prefer-offline --no-audit && npm cache clean --force

# --- playwright chromium ------------------------------------------------------
# Dedicated layer, ~5m40s when fresh, fully cached otherwise. Stays cached as
# long as the root package-lock.json (which pins playwright) doesn't change.
# `--with-deps` keeps apt-pkg resolution correct on Debian 13 (where several
# libs were renamed with t64 suffixes); only the apt-install round-trip is
# spent on cache misses, and `--only-shell` keeps the chromium download minimal.
RUN npx playwright install --with-deps chromium --only-shell

# --- web (dashboard) deps -----------------------------------------------------
# Separate from root deps so web/package-lock.json churn doesn't invalidate
# the Playwright layer above.
COPY web/package.json web/package-lock.json web/
RUN cd web && npm install --prefer-offline --no-audit && npm cache clean --force

COPY --chown=hermes:hermes . .

RUN cd web && npm run build

RUN chown hermes:hermes /opt/hermes
USER hermes
RUN uv venv && \
    uv pip install --no-cache-dir -e ".[all]"

# HackClaw plugin (https://github.com/hypermari0/hackclaw): clone into the
# image, apply the in-tree TAIKAI MCP-dispatch patch (until upstream merges),
# then install into the venv. Skill + plugin dirs are symlinked into the
# Railway volume at runtime by docker/railway-launcher.sh.
RUN git clone --depth 1 https://github.com/hypermari0/hackclaw.git /opt/hermes/hackclaw && \
    git -C /opt/hermes/hackclaw apply /opt/hermes/docker/hackclaw-taikai-mcp.patch && \
    uv pip install --no-cache-dir -e /opt/hermes/hackclaw

# Back to root so the entrypoint can chown Railway's root-owned volume at
# /opt/data, then gosu-drop to the hermes user. (Railway mounts volumes as
# root; without this, mkdir under /opt/data fails.)
USER root

ENV HERMES_WEB_DIST=/opt/hermes/hermes_cli/web_dist
ENV HERMES_HOME=/opt/data
ENV PATH="/opt/data/.local/bin:${PATH}"
# No VOLUME directive: Railway manages the /opt/data volume via `railway volume add`.

ENTRYPOINT [ "/opt/hermes/docker/railway-launcher.sh" ]
